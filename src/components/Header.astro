---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/stream', label: 'Stream' },
  { href: '/now', label: 'Now' },
  { href: '/about', label: 'About' },
];
---

<header class="bg-background">
  <div class="mx-auto max-w-2xl px-6 pt-8 sm:px-8 sm:pt-12">
    <nav class="flex items-center justify-between">
      <!-- Name -->
      <a href="/" class="text-foreground font-mono text-2xl no-underline">
        /alex
      </a>

      <!-- Navigation Links -->
      <ul class="flex items-center gap-5">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'hover:text-foreground font-mono text-sm no-underline hover:underline',
                  currentPath === item.href ||
                  (item.href === '/stream' && currentPath === '/')
                    ? 'text-foreground font-medium underline'
                    : 'text-foreground-tertiary',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
