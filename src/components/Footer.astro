---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-background">
  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Spotify Placeholder -->
    <div
      class="mb-6 rounded-lg border border-border bg-card p-4 text-center text-sm text-muted-foreground"
    >
      🎵 Music player coming soon
    </div>

    <!-- Footer Links & Copyright -->
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-muted-foreground">
        © {currentYear} Alex Rosenkranz
      </p>

      <div class="flex items-center gap-4">
        <a
          href="/rss.xml"
          class="text-sm text-muted-foreground no-underline hover:text-primary"
        >
          RSS
        </a>
        <a
          href="https://github.com/alexrosenkranz"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-muted-foreground no-underline hover:text-primary"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/alex-rosenkranz"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-muted-foreground no-underline hover:text-primary"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</footer>
