---
import NowPlaying from '@/components/NowPlaying.tsx';

const currentYear = new Date().getFullYear();
---

<footer class="bg-background mt-auto">
  <div class="mx-auto max-w-2xl px-6 py-16 sm:px-8">
    <hr class="border-foreground-quaternary mb-8 border-dashed" />
    <div class="mb-8">
      <NowPlaying client:load />
    </div>

    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-foreground-quaternary font-mono text-sm">
        &copy; {currentYear}
      </p>

      <div class="flex items-center gap-4">
        <a
          href="/rss.xml"
          class="text-foreground-tertiary hover:text-foreground font-mono text-sm no-underline hover:underline"
        >
          RSS
        </a>
        <a
          href="https://github.com/arosenkranz"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground-tertiary hover:text-foreground font-mono text-sm no-underline hover:underline"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/alex-rosenkranz"
          target="_blank"
          rel="noopener noreferrer"
          class="text-foreground-tertiary hover:text-foreground font-mono text-sm no-underline hover:underline"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</footer>
