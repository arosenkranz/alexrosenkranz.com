---
interface Props {
  links: {
    spotify?: string;
    bandcamp?: string;
    youtube?: string;
    soundcloud?: string;
    mixcloud?: string;
  };
}

const { links } = Astro.props;

// Filter undefined links and capitalize service names
const availableLinks = Object.entries(links)
  .filter(([, url]) => url !== undefined)
  .map(([service, url]) => ({
    service: service.charAt(0).toUpperCase() + service.slice(1),
    url: url as string,
  }));

if (availableLinks.length === 0) {
  return null;
}
---

<div class="border-foreground-quaternary mt-8 border-t pt-8">
  <h3
    class="text-foreground-tertiary mb-4 font-mono text-sm tracking-wide uppercase"
  >
    Listen Elsewhere
  </h3>

  <ul class="flex flex-col gap-2">
    {
      availableLinks.map(({ service, url }) => (
        <li>
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-foreground inline-flex items-center gap-2 font-mono text-sm no-underline hover:underline"
          >
            <span>→</span>
            <span>{service}</span>
          </a>
        </li>
      ))
    }
  </ul>
</div>
