---
import type { CollectionEntry } from 'astro:content';
import { formatDateShort } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, publishedAt, tags, url } = post.data;
const hasBody = post.body && post.body.trim().length > 0;

// Get the first tag for display
const primaryTag = tags[0];

// Construct the post detail URL
const postUrl = `/posts/${post.slug}`;
---

<article
  class="group border-foreground bg-card relative cursor-pointer border-2 p-8"
>
  <!-- Main clickable area: links to post detail -->
  <a
    href={postUrl}
    class="absolute inset-0 z-0"
    aria-label={`Read more about ${title}`}
  >
  </a>

  <!-- Header: Tag and Date -->
  <div
    class="pointer-events-none relative mb-4 flex items-center justify-between text-xs"
  >
    <span
      class="border-foreground text-foreground border px-2 py-1 font-mono font-medium"
    >
      {primaryTag}
    </span>
    <time
      datetime={publishedAt.toISOString()}
      class="text-muted-foreground font-mono"
    >
      {formatDateShort(publishedAt)}
    </time>
  </div>

  <!-- Title -->
  <h3
    class="text-foreground pointer-events-none relative mb-3 text-xl font-semibold"
  >
    {title}
  </h3>

  <!-- Body Content (if present) -->
  {
    hasBody && (
      <div class="prose prose-sm text-muted-foreground pointer-events-none relative mb-6">
        <p class="line-clamp-3">{post.body}</p>
      </div>
    )
  }

  <!-- External Link (if present) - positioned above the card link -->
  {
    url && (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="external-link text-foreground pointer-events-auto relative z-10 inline-flex items-center gap-1 font-mono text-sm no-underline hover:underline"
      >
        <span>→</span>
        <span>{new URL(url).hostname}</span>
      </a>
    )
  }
</article>

<script>
  // Prevent external links from triggering the card's main link
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('.external-link')) {
      e.stopPropagation();
    }
  });
</script>
