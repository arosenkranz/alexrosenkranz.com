---
import type { CollectionEntry } from 'astro:content';
import { formatDateShort } from '@/lib/utils';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, publishedAt, tags, url } = post.data;
const hasBody = post.body && post.body.trim().length > 0;

// Get the first tag for display
const primaryTag = tags[0];
---

<article
  class="group rounded-lg border border-border bg-card p-6 transition-shadow hover:shadow-md"
>
  <!-- Header: Tag and Date -->
  <div class="mb-3 flex items-center justify-between text-xs">
    <span
      class="rounded-full bg-muted px-2 py-1 font-medium text-muted-foreground"
    >
      {primaryTag}
    </span>
    <time datetime={publishedAt.toISOString()} class="text-muted-foreground">
      {formatDateShort(publishedAt)}
    </time>
  </div>

  <!-- Title -->
  <h3 class="mb-2 text-lg font-semibold text-foreground">
    {title}
  </h3>

  <!-- Body Content (if present) -->
  {
    hasBody && (
      <div class="prose prose-sm mb-4 text-muted-foreground">
        <p class="line-clamp-3">{post.body}</p>
      </div>
    )
  }

  <!-- External Link (if present) -->
  {
    url && (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm text-primary no-underline hover:underline"
      >
        <span>→</span>
        <span>{new URL(url).hostname}</span>
      </a>
    )
  }
</article>
