---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

const lastUpdated = 'January 13, 2025';
---

<BaseLayout
  title="Now - Alex Rosenkranz"
  description="What I'm up to right now."
>
  <Header />

  <main class="mx-auto max-w-2xl flex-1 px-6 py-16 sm:px-8 sm:py-24">
    <h1 class="text-foreground mb-2 text-2xl font-semibold">
      What I'm doing now
    </h1>
    <p class="text-foreground-secondary mb-2">
      A snapshot of what I'm currently focused on.
    </p>
    <p class="text-foreground-quaternary mb-12 font-mono text-sm">
      Last updated: {lastUpdated}
    </p>

    <!-- Projects -->
    <section class="mb-12">
      <h2 class="text-foreground-quaternary mb-4 font-mono text-sm">
        projects
      </h2>
      <ul class="text-foreground-secondary flex flex-col gap-3 leading-relaxed">
        <li>
          <span class="text-foreground font-medium"
            >Personal Website Rebuild:</span
          > Building this site with Astro, Tailwind CSS, and Cloudflare Pages. Implementing
          a stream-based content model for quick posts and longer articles.
        </li>
        <li>
          <span class="text-foreground font-medium">Homelab Setup:</span> Running
          Home Assistant and Music Assistant on a Raspberry Pi 5, with various Docker
          services monitored by Datadog.
        </li>
      </ul>
    </section>

    <hr class="border-foreground-quaternary mb-12 border-dashed" />

    <!-- Learning -->
    <section class="mb-12">
      <h2 class="text-foreground-quaternary mb-4 font-mono text-sm">
        learning
      </h2>
      <ul class="text-foreground-secondary flex flex-col gap-2 leading-relaxed">
        <li>Astro framework and static site generation patterns</li>
        <li>Self-hosting services and Linux administration</li>
        <li>Terraform for infrastructure as code</li>
        <li>AWS cloud fundamentals</li>
      </ul>
    </section>

    <hr class="border-foreground-quaternary mb-12 border-dashed" />

    <!-- Reading -->
    <section class="mb-12">
      <h2 class="text-foreground-quaternary mb-4 font-mono text-sm">reading</h2>
      <ul class="text-foreground-secondary flex flex-col gap-2 leading-relaxed">
        <li>Various articles on web performance and observability</li>
        <li>Technical documentation for homelab projects</li>
      </ul>
    </section>

    <hr class="border-foreground-quaternary mb-12 border-dashed" />

    <!-- Work -->
    <section class="mb-12">
      <h2 class="text-foreground-quaternary mb-4 font-mono text-sm">work</h2>
      <p class="text-foreground-secondary leading-relaxed">
        Working at Datadog on observability and developer tools. Focused on
        making complex systems easier to understand and debug.
      </p>
    </section>

    <hr class="border-foreground-quaternary mb-12 border-dashed" />

    <p class="text-foreground-quaternary text-sm">
      Inspired by Derek Sivers' <a
        href="https://nownownow.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-foreground-tertiary underline">/now</a
      > movement. This page is updated monthly or whenever things change significantly.
    </p>
  </main>

  <Footer />
</BaseLayout>
