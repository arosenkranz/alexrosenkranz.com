---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

const lastUpdated = 'February 23, 2026';
---

<BaseLayout title="Now - Alex Rosenkranz" description="What I'm up to lately.">
  <Header />

  <main class="mx-auto max-w-2xl flex-1 px-6 py-16 sm:px-8 sm:py-24">
    <h1 class="text-foreground mb-2 text-2xl font-semibold">
      What I'm up to lately.
    </h1>
    <p class="text-foreground-secondary mb-2">
      A snapshot of what I'm currently focused on.
    </p>
    <p class="text-foreground-quaternary mb-12 font-mono text-sm">
      Last updated: {lastUpdated}
    </p>

    <!-- Projects -->
    <section class="mb-12">
      <h2 class="text-foreground-quaternary mb-4 font-mono text-sm">
        projects
      </h2>
      <ul class="text-foreground-secondary flex flex-col gap-3 leading-relaxed">
        <li>
          <span class="text-foreground font-medium"
            >Personal Website Rebuild:</span
          > Building this site with Astro, Tailwind CSS, and Cloudflare Pages (and
          Claude Code). Implementing a stream-based content model for quick posts
          and longer articles.
        </li>
        <li>
          <span class="text-foreground font-medium">Homelab Setup:</span> Running
          Home Assistant and Music Assistant on a Raspberry Pi, with various Docker
          services monitored by Datadog.
        </li>
      </ul>
    </section>

    <hr class="border-foreground-quaternary mb-12 border-dashed" />

    <!-- Reading -->
    <section class="mb-12">
      <h2 class="text-foreground-quaternary mb-4 font-mono text-sm">reading</h2>
      <ul class="text-foreground-secondary flex flex-col gap-2 leading-relaxed">
        <li>
          <a
            href="https://nadh.in/blog/code-is-cheap/"
            rel="noopener noreferrer">Code is cheap. Show me the talk.</a
          >
        </li>
      </ul>
    </section>

    <hr class="border-foreground-quaternary mb-12 border-dashed" />

    <!-- Work -->
    <section class="mb-12">
      <h2 class="text-foreground-quaternary mb-4 font-mono text-sm">work</h2>
      <p class="text-foreground-secondary leading-relaxed">
        Currently gearing up for new workshops we're building for
        [DASH](https://dash.datadoghq.com/), and keeping up with the daily
        advances in AI tooling.
      </p>
    </section>

    <hr class="border-foreground-quaternary mb-12 border-dashed" />

    <p class="text-foreground-quaternary text-sm">
      Inspired by Derek Sivers' <a
        href="https://sive.rs/nowff"
        target="_blank"
        rel="noopener noreferrer"
        class="text-foreground-tertiary underline">/now</a
      >. This page is updated monthly or whenever things change significantly.
    </p>
  </main>

  <Footer />
</BaseLayout>
