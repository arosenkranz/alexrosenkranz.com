---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import PostCard from '@/components/PostCard.astro';

// Get all posts, filter drafts, and sort by date
const allPosts = await getCollection('posts');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

// Get unique tags for future filtering UI
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout
  title="Alex Rosenkranz"
  description="A stream of things I find interesting: articles, music, code, and more."
>
  <Header />

  <main class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Page Header -->
    <div class="mb-12">
      <h1 class="text-foreground mb-4 text-4xl font-bold tracking-tight">
        Stream
      </h1>
      <p class="text-muted-foreground text-lg leading-relaxed">
        A collection of things I find interesting—articles I'm reading, music
        I'm listening to, projects I'm working on, and thoughts I'm thinking.
        Updated frequently.
      </p>

      <!-- TODO: Tag filter UI (non-functional for MVP) -->
      <div class="mt-6 flex flex-wrap gap-2">
        {
          allTags.map((tag) => (
            <button
              class="border-border bg-background text-muted-foreground hover:bg-muted rounded-full border px-3 py-1 text-sm transition-colors"
              disabled
            >
              {tag}
            </button>
          ))
        }
      </div>
    </div>

    <!-- Posts Grid -->
    <div class="grid gap-6 sm:grid-cols-2">
      {posts.map((post) => <PostCard post={post} />)}
    </div>

    <!-- Empty State -->
    {
      posts.length === 0 && (
        <div class="border-border bg-card rounded-lg border p-12 text-center">
          <p class="text-muted-foreground">No posts yet. Check back soon!</p>
        </div>
      )
    }
  </main>

  <Footer />
</BaseLayout>
