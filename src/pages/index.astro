---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import PostListItem from '@/components/PostListItem.astro';

// Get all posts, filter drafts, and sort by date
const allPosts = await getCollection('posts');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const latestPosts = posts.slice(0, 5);
---

<BaseLayout
  title="Alex Rosenkranz"
  description="Personal website and digital garden."
>
  <Header />

  <main class="mx-auto max-w-2xl flex-1 px-6 py-16 sm:px-8 sm:py-24">
    <!-- Intro -->
    <section class="mb-16">
      <p
        class="border-foreground-quaternary border-l-2 pl-4 text-lg leading-relaxed font-medium"
      >
        Hi, I'm Alex. I work at Datadog and spend my time building things on the
        web, tinkering with a homelab, and collecting interesting ideas. This is
        my corner of the internet.
      </p>
    </section>

    <!-- Social links -->
    <section class="mb-16 flex items-center gap-4">
      <a
        href="https://github.com/arosenkranz"
        target="_blank"
        rel="noopener noreferrer"
        class="text-foreground-tertiary hover:text-foreground text-sm no-underline hover:underline"
      >
        GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/alex-rosenkranz"
        target="_blank"
        rel="noopener noreferrer"
        class="text-foreground-tertiary hover:text-foreground text-sm no-underline hover:underline"
      >
        LinkedIn
      </a>
      <a
        href="/rss.xml"
        class="text-foreground-tertiary hover:text-foreground text-sm no-underline hover:underline"
      >
        RSS
      </a>
    </section>

    <!-- Writing -->
    <section>
      <div class="mb-6 flex items-baseline justify-between">
        <h2 class="text-foreground-quaternary font-mono text-sm">lately</h2>
        <a
          href="/stream"
          class="text-foreground-tertiary hover:text-foreground font-mono text-sm no-underline hover:underline"
        >
          see all &rarr;
        </a>
      </div>

      <ul class="flex flex-col gap-1">
        {latestPosts.map((post) => <PostListItem post={post} />)}
      </ul>
    </section>
  </main>

  <Footer />
</BaseLayout>
