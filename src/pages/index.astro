---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import PostListItem from '@/components/PostListItem.astro';
import JsonLd from '@/components/JsonLd.astro';
import { SITE_CONFIG } from '@/lib/site-config';
import { buildWebSiteSchema, buildBreadcrumbSchema } from '@/lib/seo';

// Get all posts, filter drafts, and sort by date
const allPosts = await getCollection('posts');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const latestPosts = posts.slice(0, 5);
---

<BaseLayout
  title="Alex Rosenkranz"
  description="Personal website and digital garden."
>
  <JsonLd
    schemas={[
      buildWebSiteSchema(SITE_CONFIG),
      buildBreadcrumbSchema([{ name: 'Home', url: SITE_CONFIG.url }]),
    ]}
  />
  <Header />

  <main class="mx-auto max-w-2xl flex-1 px-6 py-16 sm:px-8 sm:py-24">
    <!-- Intro -->
    <section class="mb-16">
      <p
        class="border-foreground-quaternary border-l-2 pl-4 text-lg leading-relaxed font-medium"
      >
        Hi, I'm Alex. I'm currently an Engineering Manager on the <a
          href="https://learn.datadoghq.com"
          target="_blank"
          rel="noopener noreferrer"
          >Customer Education &amp; Training team at Datadog</a
        >. This is my corner of the internet to share things I'm into, working
        on, learning, and doing with my life.
      </p>
    </section>

    <!-- Writing -->
    <section>
      <div class="mb-6 flex items-baseline justify-between">
        <h2 class="text-foreground-tertiary text-base font-medium">lately</h2>
        <a
          href="/stream"
          class="text-foreground-tertiary hover:text-foreground text-sm no-underline hover:underline"
        >
          see all &rarr;
        </a>
      </div>

      <ul class="flex flex-col gap-1">
        {latestPosts.map((post) => <PostListItem post={post} />)}
      </ul>
    </section>
  </main>

  <Footer />
</BaseLayout>
