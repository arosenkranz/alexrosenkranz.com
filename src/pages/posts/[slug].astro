---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { formatDateShort } from '@/lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, publishedAt, tags, url } = post.data;
const { Content } = await post.render();
const hasBody = post.body && post.body.trim().length > 0;
const isExternalLink = !!url;
---

<BaseLayout title={title}>
  <Header />

  <main class="mx-auto max-w-2xl flex-1 px-6 py-16 sm:px-8 sm:py-24">
    <!-- Back link -->
    <a
      href="/stream"
      class="text-foreground-tertiary mb-8 inline-flex items-center gap-2 font-mono text-sm no-underline hover:underline"
    >
      <span>&larr;</span>
      <span>Back to stream</span>
    </a>

    <article>
      <!-- Header -->
      <header class="mb-8">
        <time
          datetime={publishedAt.toISOString()}
          class="text-foreground-tertiary mb-2 block font-mono text-sm"
        >
          {formatDateShort(publishedAt)}
        </time>
        {
          tags.length > 0 && (
            <p class="text-foreground-quaternary mb-3 font-mono text-sm">
              {tags.join(', ')}
            </p>
          )
        }
        <h1 class="text-foreground text-2xl font-semibold">{title}</h1>
      </header>

      <!-- Main content -->
      <div class="prose prose-slate dark:prose-invert max-w-none">
        {hasBody && <Content />}
      </div>

      <!-- External link -->
      {
        isExternalLink && (
          <div class="border-foreground-quaternary mt-8 border-t pt-8">
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-foreground hover:text-foreground inline-flex items-center gap-2 no-underline hover:underline"
            >
              <span>View original</span>
              <span>&rarr;</span>
            </a>
            <p class="text-foreground-tertiary mt-1 text-sm">
              {new URL(url).hostname}
            </p>
          </div>
        )
      }
    </article>
  </main>

  <Footer />
</BaseLayout>
